# =============================================================================
# RAG Chatbot — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit the .env file — it contains secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# CLOUD PROVIDER — which cloud to use at runtime
# Options: "aws" or "azure"
# This single variable controls which LLM, vector store, storage, and
# history backend the app uses.
# -----------------------------------------------------------------------------
CLOUD_PROVIDER=aws

# -----------------------------------------------------------------------------
# APPLICATION SETTINGS
# -----------------------------------------------------------------------------
APP_NAME=rag-chatbot
APP_ENV=dev
APP_PORT=8000
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# RAG SETTINGS
# -----------------------------------------------------------------------------
# How many document chunks to retrieve per query (higher = more context but more tokens)
RAG_TOP_K=5
# Maximum tokens per chunk when splitting documents
RAG_CHUNK_SIZE=1000
# Overlap between chunks (prevents cutting sentences in half)
RAG_CHUNK_OVERLAP=200

# -----------------------------------------------------------------------------
# AWS SETTINGS (only needed if CLOUD_PROVIDER=aws)
# -----------------------------------------------------------------------------
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# Amazon Bedrock (LLM)
AWS_BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
AWS_BEDROCK_REGION=eu-central-1

# Amazon OpenSearch Serverless (Vector Store)
AWS_OPENSEARCH_ENDPOINT=
AWS_OPENSEARCH_INDEX_NAME=rag-chatbot-vectors

# Amazon S3 (Document Storage)
AWS_S3_BUCKET_NAME=rag-chatbot-documents

# Amazon DynamoDB (Conversation History)
AWS_DYNAMODB_TABLE_NAME=rag-chatbot-conversations

# -----------------------------------------------------------------------------
# AZURE SETTINGS (only needed if CLOUD_PROVIDER=azure)
# -----------------------------------------------------------------------------
# Azure OpenAI (LLM)
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Azure OpenAI Embeddings
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# Azure AI Search (Vector Store)
AZURE_SEARCH_ENDPOINT=https://<your-resource>.search.windows.net
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_INDEX_NAME=rag-chatbot-vectors

# Azure Blob Storage (Document Storage)
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER_NAME=rag-chatbot-documents

# Azure Cosmos DB (Conversation History)
AZURE_COSMOS_ENDPOINT=https://<your-resource>.documents.azure.com:443/
AZURE_COSMOS_KEY=
AZURE_COSMOS_DATABASE_NAME=rag-chatbot
AZURE_COSMOS_CONTAINER_NAME=conversations

# -----------------------------------------------------------------------------
# MONITORING (optional — for production)
# -----------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=rag-chatbot
ENABLE_TRACING=false
