# =============================================================================
# RAG Chatbot — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit the .env file — it contains secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# CLOUD PROVIDER — which backend to use at runtime
# Options: "aws" | "azure" | "local"
# This single variable controls which LLM, vector store, storage, and
# history backend the app uses.
# Start with "local" for zero-cost development (Ollama + ChromaDB).
# -----------------------------------------------------------------------------
CLOUD_PROVIDER=local

# -----------------------------------------------------------------------------
# APPLICATION SETTINGS
# -----------------------------------------------------------------------------
APP_NAME=rag-chatbot
APP_ENV=dev
APP_PORT=8000
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# LOCAL SETTINGS (only needed if CLOUD_PROVIDER=local)
# Free, no accounts needed — just install Ollama and pull models.
# -----------------------------------------------------------------------------
# Ollama (LLM + Embeddings — runs on your machine)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
CHROMA_COLLECTION_NAME=rag-chatbot

# ChromaDB (Vector Store — runs in-process, stores to local disk)
CHROMA_PERSIST_DIRECTORY=./data/chromadb

# Conversation History: in-memory (no config needed, resets on restart)

# -----------------------------------------------------------------------------
# RAG SETTINGS
# -----------------------------------------------------------------------------
# How many document chunks to retrieve per query (higher = more context but more tokens)
RAG_TOP_K=5
# Maximum tokens per chunk when splitting documents
RAG_CHUNK_SIZE=1000
# Overlap between chunks (prevents cutting sentences in half)
RAG_CHUNK_OVERLAP=200

# -----------------------------------------------------------------------------
# AWS SETTINGS (only needed if CLOUD_PROVIDER=aws)
# -----------------------------------------------------------------------------
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# Amazon Bedrock (LLM)
AWS_BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
AWS_BEDROCK_REGION=eu-central-1

# Amazon OpenSearch Serverless (Vector Store)
AWS_OPENSEARCH_ENDPOINT=
AWS_OPENSEARCH_INDEX_NAME=rag-chatbot-vectors

# Amazon S3 (Document Storage)
AWS_S3_BUCKET_NAME=rag-chatbot-documents

# Amazon DynamoDB (Conversation History)
AWS_DYNAMODB_TABLE_NAME=rag-chatbot-conversations

# Amazon DynamoDB (Vector Store — cheap alternative to OpenSearch, ~$0/month)
# Set VECTOR_STORE_TYPE=dynamodb to use this instead of OpenSearch
AWS_DYNAMODB_VECTOR_TABLE_NAME=rag-chatbot-vectors

# Vector Store Override (optional — default: auto, uses provider's native store)
# Options: "auto" | "dynamodb"
VECTOR_STORE_TYPE=auto

# -----------------------------------------------------------------------------
# AZURE SETTINGS (only needed if CLOUD_PROVIDER=azure)
# -----------------------------------------------------------------------------
# Azure OpenAI (LLM)
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Azure OpenAI Embeddings
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# Azure AI Search (Vector Store)
AZURE_SEARCH_ENDPOINT=https://<your-resource>.search.windows.net
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_INDEX_NAME=rag-chatbot-vectors

# Azure Blob Storage (Document Storage)
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER_NAME=rag-chatbot-documents

# Azure Cosmos DB (Conversation History)
AZURE_COSMOS_ENDPOINT=https://<your-resource>.documents.azure.com:443/
AZURE_COSMOS_KEY=
AZURE_COSMOS_DATABASE_NAME=rag-chatbot
AZURE_COSMOS_CONTAINER_NAME=conversations

# -----------------------------------------------------------------------------
# MONITORING (optional — for production)
# -----------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=rag-chatbot
ENABLE_TRACING=false

# -----------------------------------------------------------------------------
# GUARDRAILS (Phase 4 — optional, works with any CLOUD_PROVIDER)
# Install extras: poetry install -E guardrails-azure  (for Azure)
# AWS guardrails use Bedrock + Comprehend (no extra install needed)
# Local guardrails use regex patterns (no extra install needed)
# -----------------------------------------------------------------------------
GUARDRAILS_ENABLED=false

# AWS Bedrock Guardrails (only if CLOUD_PROVIDER=aws)
AWS_BEDROCK_GUARDRAIL_ID=
AWS_BEDROCK_GUARDRAIL_VERSION=DRAFT

# Azure AI Content Safety + Language (only if CLOUD_PROVIDER=azure)
AZURE_CONTENT_SAFETY_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com/
AZURE_CONTENT_SAFETY_KEY=
AZURE_LANGUAGE_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com/
AZURE_LANGUAGE_KEY=

# -----------------------------------------------------------------------------
# RE-RANKER (Phase 4 — optional, works with any CLOUD_PROVIDER)
# Install extras: poetry install -E reranker  (for local CrossEncoder)
# AWS uses Bedrock Reranker (no extra install)
# Azure uses AI Search Semantic Ranker (no extra install)
# -----------------------------------------------------------------------------
RERANKER_ENABLED=false
RERANKER_CANDIDATE_COUNT=20

# -----------------------------------------------------------------------------
# HYBRID SEARCH (Phase 4 — optional, works with any CLOUD_PROVIDER)
# Install extras: poetry install -E hybrid  (for local BM25)
# AWS/Azure use native hybrid search in OpenSearch/AI Search
# -----------------------------------------------------------------------------
HYBRID_SEARCH_ENABLED=false
HYBRID_SEARCH_ALPHA=0.7
