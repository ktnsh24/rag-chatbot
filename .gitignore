# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
ENV/

# Environment files (contain secrets)
.env
.env.local
.env.*.local

# IDE
.idea/
.vscode/
*.swp
*.swo

# Poetry
poetry.lock

# Distribution
dist/
build/
*.egg-info/

# Data files (user documents — don't commit)
data/*
!data/.gitkeep

# Vector DB local storage
chroma_db/

# OS files
.DS_Store
Thumbs.db

# Docker
docker-compose.override.yml

# Terraform
infra/**/.terraform/
infra/**/*.tfstate
infra/**/*.tfstate.backup
infra/**/.terraform.lock.hcl
infra/**/*.tfvars
!infra/**/*.tfvars.example

# Test / coverage
htmlcov/
.coverage
.pytest_cache/

# Logs
*.log
logs/

# Lab results contain ingested document content — keep local, regenerate per-environment
scripts/lab_results/

# Backup .env files (may contain real secrets)
.env.*backup
.env.*.bak
.env.local
.env.azure*
.env.aws*

# Internal working notes — never publish
replacement_summary.txt
*_summary.txt

# Personal lab runners (may contain real account IDs / paths)
scripts/*_personal.sh
scripts/*_personal.py

# Terraform build artifacts
infra/**/.build/
